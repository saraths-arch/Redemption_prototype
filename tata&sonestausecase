  .rad .rl{font-size:14px;font-weight:500;color:var(--ink)} .rad .rb{font-size:12px;color:var(--sec);margin-top:2px}
  /* drag-to-rank list */
  .pri-list{border:1px solid var(--border);border-radius:var(--rad);overflow:hidden;max-width:600px;margin-top:4px}
  .pri-row{display:flex;align-items:center;gap:12px;padding:13px 14px;border-bottom:1px solid var(--line);background:#fff}
  .pri-row:last-child{border-bottom:none} .pri-row.dis{opacity:.6}
  .pri-row.draggable{cursor:grab} .pri-row.dragover{background:var(--green1)} .pri-row.dragging{opacity:.4}
  .pri-grip{color:var(--tert);font-size:16px} .pri-row.draggable .pri-grip{cursor:grab}
  .pri-num{width:20px;height:20px;border-radius:50%;background:var(--n3);font-size:12px;font-weight:500;display:flex;align-items:center;justify-content:center;color:var(--sec);flex:none}
  .pri-nm{flex:1;font-size:14px;font-weight:500;color:var(--ink)} .pri-nm small{display:block;font-weight:400;font-size:12px;color:var(--sec)}
  .pri-hint{margin-left:auto;font-size:12px;color:var(--tert)}
</style>
