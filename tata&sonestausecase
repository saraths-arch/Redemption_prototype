<body>
  <div class="protohint">
    <span class="protochip">PROTOTYPE</span>
    <span class="steps"><b>Flow:</b> <span id="s1" class="on">1 · Program workflow</span> › <span id="s2">2 · Advanced settings</span> › <span id="s3">3 · Redemption scope</span></span>
    <span style="margin-left:auto">Styled from the live Capillary prod UI</span>
  </div>
  <div class="scenariobar">
    <label>Demo scenario</label>
    <select id="scenarioSel" onchange="setScenario(this.value)">
      <option value="0">Scenario 1 — Org active · "Redeem group points" added → editable</option>
      <option value="1">Scenario 2 — Org active · no group action added → system assumes Individual</option>
      <option value="2">Scenario 3 — Org inactive → action disabled · Individual</option>
    </select>
    <span id="scenarioOut" class="scn-out"></span>
  </div>

  <!-- PROGRAM SCREEN -->
  <div id="programScreen">
    <div class="ghead">
      <div class="logo">▦ Loyalty+</div>
      <div class="org"><span class="av">T</span> Tata Digital SIT ▾</div>
      <nav><a class="active">Programs</a><a>Promotions</a><a>Creatives</a></nav>
      <div class="right"><span title="Settings">⚙</span><span>✦</span><span class="av2">◍</span></div>
    </div>
    <div class="thead">
      <div style="display:flex;align-items:flex-start">
        <span class="arr" title="Back">←</span>
        <div><h1>Tata NeuPass</h1><div class="desc">Description : Tata NeuPass</div></div>
      </div>
      <div class="acts">
        <button class="link" onclick="openSettings('empty')">Advanced settings</button>
        <button class="btn btn-primary" disabled>Publish changes</button>
      </div>
    </div>
    <div class="pbody">
      <div class="sec-row"><div class="sec-num">1</div><div><h3>Strategies</h3><p>Define the basic building blocks of your program in this section</p></div></div>
      <div class="sec-row"><div class="sec-num">2</div><div><h3>Trackers</h3><p>Create Custom Metrics to track program milestones and eligibilities</p></div></div>
      <div class="sec-row" style="border-bottom:none"><div class="sec-num">3</div><div><h3>Workflows</h3><p>Connect strategies and trackers together and define the real-time flows of the program</p></div></div>
      <div class="promo-banner"><div class="pico">📡</div><div class="txt">Promotions have now been migrated to its own section with a new and improved interface!</div><div class="lnk">⤤ Open Loyalty promotions</div></div>
      <div class="wf-actrow"><span class="lbl">Customer Activity</span><div class="wf-act"><span>PointsRedemption</span><span class="chev">›</span></div></div>
      <div class="builder" id="builderHost"></div>
      <div class="note tips" id="wfNote" style="margin-top:18px"></div>
    </div>
  </div>

  <!-- ADVANCED SETTINGS OVERLAY -->
  <div class="overlay" id="setOverlay" onclick="if(event.target===this)closeSettings()">
    <div class="panel">
      <div class="panel-head">
        <h2 id="panelTitle">Advanced settings</h2>
        <div class="org">Organisation <b>Tata Digital SIT</b></div>
        <button class="xbtn" title="Close" onclick="closeSettings()">&times;</button>
      </div>
      <div class="panel-body">
        <nav class="nav">
          <div class="nav-item" onclick="selectSection('generic','Tiers')">Tiers</div>
          <div class="nav-item" onclick="selectSection('generic','Points')">Points</div>
          <div class="nav-item" onclick="selectSection('generic','Payment methods')">Payment methods</div>
          <div class="nav-item" onclick="selectSection('generic','Communication Channels')">Communication Channels</div>
          <div class="nav-item" onclick="selectSection('generic','Liability settings')">Liability settings</div>
          <div class="nav-item" onclick="selectSection('generic','Subscription Program')">Subscription Program</div>
          <div class="nav-item" onclick="selectSection('generic','Delayed accrual')">Delayed accrual</div>
          <div class="nav-item" onclick="selectSection('generic','Reward currencies')">Reward currencies</div>
          <div class="nav-item" onclick="selectSection('generic','Points allocation limits')">Points allocation limits</div>
          <div class="nav-item" onclick="selectSection('generic','Loyalty promotions')">Loyalty promotions</div>
          <div class="nav-item" id="navRedemption" onclick="selectSection('redemption')">Redemption scope <span class="dot"></span></div>
          <div class="nav-item" id="navPriority" onclick="selectSection('priority')">Redemption priority <span class="dot"></span></div>
        </nav>
        <div class="content" id="advContent"></div>
      </div>
    </div>
  </div>

  <div id="drawerHost"></div>
  <div class="toast-wrap" id="toastWrap"></div>

<script>
  const STRATS=['GroupRedemption','CFT_redemption','Points_transfer_redemption_tataneu','redemption_config','RedemptionThreshold','test_usergroupprimary','test_usergroupsecondary'];
  let mode='view', status='Live';
  // Redemption scope — by point-source category. group:true = Shared (can travel).
  let CATS=[
    {label:"Base / everyday points",sub:"Regular transaction points",group:true},
    {label:"Promotional points",sub:"From loyalty promotions",expandable:true,open:false,unit:"promotion",query:"",promos:[
      {label:"IHCL Stay Promotion",sub:"Bill promo",group:false},
      {label:"Weekend Spend Bonus",sub:"Bill promo",group:true},
      {label:"Birthday Bonus",sub:"Customer promo",group:false},
      {label:"Festive Double Points",sub:"Bill promo",group:false},
      {label:"Tata Neu Card Accelerator",sub:"Line promo",group:true},
      {label:"First Stay Welcome Bonus",sub:"Customer promo",group:false},
      {label:"Spa & Dining Bonus",sub:"Line promo",group:false},
      {label:"Anniversary Reward",sub:"Customer promo",group:false},
      {label:"Monsoon Getaway Offer",sub:"Bill promo",group:true},
      {label:"Referral Bonus",sub:"Customer promo",group:false}
    ]},
    {label:"Goodwill points",sub:"Member Care adjustments",group:false},
    {label:"Imported points",sub:"Data import",group:true},
    {label:"Campaign points",sub:"Engage+ campaigns",expandable:true,open:false,unit:"campaign",query:"",promos:[
      {label:"Diwali Cashback",sub:"Engage+ campaign",group:true},
      {label:"App Install Bonus",sub:"Engage+ campaign",group:false},
      {label:"Refer-a-Friend",sub:"Engage+ campaign",group:false},
      {label:"Weekend Flash Bonus",sub:"Engage+ campaign",group:true},
      {label:"Newsletter Signup",sub:"Engage+ campaign",group:false}
    ]},
    {label:"Benefits",sub:"Tier & membership benefits",expandable:true,open:false,unit:"benefit",query:"",promos:[
      {label:"Room Upgrade",sub:"Tier benefit",group:false},
      {label:"Late Checkout",sub:"Tier benefit",group:false},
      {label:"Welcome Drink",sub:"Tier benefit",group:true},
      {label:"Airport Transfer",sub:"Membership benefit",group:false},
      {label:"Complimentary Breakfast",sub:"Tier benefit",group:true},
      {label:"Spa Discount",sub:"Membership benefit",group:false},
      {label:"Priority Check-in",sub:"Tier benefit",group:false}
    ]}
  ];
  const cloneCats=()=>JSON.parse(JSON.stringify(CATS));
  let savedCATS=cloneCats();

  /* ---- scenarios ---- */
  const SCENARIOS=[{org:true,added:true,branch:'True'},{org:true,added:false,branch:null},{org:false,added:false,branch:null}];
  let SCi=0;
  function gAllowed(){const s=SCENARIOS[SCi];return s.org&&s.added&&s.branch==='True';}
  function gReason(){const s=SCENARIOS[SCi];
    if(!s.org) return `Group redemption is inactive in Organisation settings — the "Redeem group points" action is disabled in the workflow, so points redeem individually.`;
    return `No "Redeem group points" action is configured in this program's workflow, so the system assumes Individual redemption for every points type.`;}
  function setScenario(i){SCi=+i;if(!gAllowed())mode='view';applyScenario();renderScn();renderBuilder();const ov=document.getElementById('setOverlay');if(ov&&ov.classList.contains('open')){if(document.getElementById('navRedemption').classList.contains('active'))renderRedemption();if(document.getElementById('navPriority').classList.contains('active'))renderPriority();}}
  function renderScn(){
    const s=SCENARIOS[SCi];
    document.getElementById('scenarioOut').innerHTML=gAllowed()?'→ <b>checkboxes editable</b> in Redemption scope':'→ <b>locked to Individual</b>';
    const wf=document.getElementById('wfNote');if(!wf)return;
    if(!s.org){wf.className='note warn';wf.innerHTML=`<span class="ic">ⓘ</span><span><span class="pfx">Note:&nbsp;</span>Group redemption is inactive in Organisation settings, so the "Redeem group points" action is disabled in this workflow. Enable group redemption in Organisation settings to use it.</span>`;}
    else if(!s.added){wf.className='note warn';wf.innerHTML=`<span class="ic">ⓘ</span><span><span class="pfx">Assumption:&nbsp;</span>No "Redeem group points" action is configured here, so the <b>system assumes Individual</b> redemption for every points type. Add the action on the True branch to configure per-type scope.</span>`;}
    else{wf.className='note tips';wf.innerHTML=`<span class="ic">💡</span><span><span class="pfx">Tips:&nbsp;</span>The per-points-type control lives under this program's <b>Advanced settings › Redemption scope</b>. &nbsp;<button class="cta" onclick="openSettings('redemption')">Open Redemption scope ›</button></span>`;}
  }

  /* ---- builder ---- */
  let B={sel:0,openMenu:null,conditions:[]};
  function applyScenario(){
    if(SCi===0) B.conditions=[{name:'Condition 1',whens:[{branch:'True',actions:[{name:'Redeem group points',strategy:'GroupRedemption'}]}]}];
    else if(SCi===1) B.conditions=[{name:'Condition 1',whens:[{branch:'True',actions:[{name:'Redeem points',strategy:'redemption_config'}]}]}];
    else B.conditions=[{name:'Condition 1',whens:[{branch:'True',actions:[]}]}];
    B.sel=0;B.openMenu=null;
  }
  function actionCount(cd){return cd.whens.reduce((n,w)=>n+w.actions.length,0);}
  function renderBuilder(){
    const host=document.getElementById('builderHost');if(!host)return;
    const c=B.conditions[B.sel];
    const left=`<div class="bcol"><input class="srch" placeholder="🔍  Search" disabled><div class="srch-note">Atleast 3 characters required</div><div class="ruleset"><div class="rs-head"><span><span class="ico">☰</span> Evaluation start <span style="color:var(--tert)">ⓘ</span></span><span style="color:var(--sec)">⌃</span></div><div class="rs-item">Set1 <span style="color:var(--sec)">⋮</span></div></div></div>`;
    const cards=B.conditions.map((cd,i)=>`<div class="cond-card ${i===B.sel?'':'un'}" onclick="selectCond(${i})"><div class="ctop"><span class="ct">${cd.name}</span>${i===B.sel?`<span class="cx" onclick="event.stopPropagation();removeCondition(${i})">✕</span>`:''}</div><div class="cs">${actionCount(cd)} action(s) setup</div></div>`).join('');
    const mid=`<div class="bcol"><div class="scope-lbl">Scope</div><div class="scope-sub">3 Scope(s) selected</div>${cards}<div class="col-foot"><button class="btn-out" onclick="addCondition()">＋ Condition</button></div></div>`;
    const ico=n=>n.indexOf('Transfer')===0?'🔁':(n.indexOf('Redeem')===0?'🏆':'🎫');
    const whens=c.whens.map((w,wi)=>{
      const acts=w.actions.length?w.actions.map((a,ai)=>`<div class="action-chip pos ${a.disabled?'dis':''}" style="margin-bottom:${a.disabled?'4px':'10px'}"><span class="tro">${ico(a.name)}</span><span class="nm">${a.name}</span><span class="st">${a.strategy}</span>${a.disabled?'':`<span class="dots" onclick="toggleChipMenu(${wi},${ai})">⋯</span>`}${(!a.disabled&&B.openMenu==='c'+wi+'_'+ai)?`<div class="menu" style="right:6px;top:46px"><div onclick="event.stopPropagation();openEditDrawer(${wi},${ai})">Edit action</div><div class="del" onclick="event.stopPropagation();deleteAction(${wi},${ai})">Delete action</div></div>`:''}</div>${a.disabled?'<div class="dis-note">🔒 Disabled — group redemption is inactive in Organisation settings.</div>':''}`).join(''):`<div class="empty-act">No actions yet — add one below.</div>`;
      const header=wi===0?'':`<div class="when-bar"><span>When</span><span class="x" onclick="removeWhen(${wi})">✕</span></div>`;
      return `${header}<div class="when-row"><span>Expression is</span><span class="seg"><b class="${w.branch==='True'?'on':'off'}" onclick="setWhenBranch(${wi},'True')">True</b><s class="${w.branch==='False'?'on':'off'}" onclick="setWhenBranch(${wi},'False')">False</s></span></div>${acts}<div style="margin:12px 0 20px"><span class="addact" onclick="openAddDrawer(${wi})">＋ Add action</span></div>`;
    }).join('');
    const both=c.whens.length>=2;
    const right=`<div class="bcol pos"><div class="exp-lbl">Expression</div><div class="expr"><span class="expr-text" contenteditable="true" spellcheck="false">currentEvent.<span class="tok">isGroupProgramRedemption</span></span><span class="ai">✦</span></div><div style="margin-top:14px">${whens}</div><div class="col-foot"><button class="btn-out" ${both?'disabled style="opacity:.45;cursor:not-allowed"':''} onclick="addWhen()">＋ When</button></div></div>`;
    host.innerHTML=`<div class="collapse">‹</div>${left}${mid}${right}`;
  }
  function selectCond(i){B.sel=i;B.openMenu=null;renderBuilder();}
  function addCondition(){B.conditions.push({name:'Condition '+(B.conditions.length+1),whens:[{branch:'True',actions:[]}]});B.sel=B.conditions.length-1;B.openMenu=null;renderBuilder();}
  function removeCondition(i){if(B.conditions.length<=1){toast('At least one condition is required.');return;}B.conditions.splice(i,1);B.sel=0;B.openMenu=null;renderBuilder();}
  function setWhenBranch(wi,b){const c=B.conditions[B.sel];if(c.whens.some((w,j)=>j!==wi&&w.branch===b)){toast('A “When” for '+b+' already exists.');return;}c.whens[wi].branch=b;B.openMenu=null;renderBuilder();}
  function addWhen(){const c=B.conditions[B.sel];if(c.whens.length>=2){toast('Both True and False branches are already added.');return;}const next=c.whens.some(w=>w.branch==='True')?'False':'True';c.whens.push({branch:next,actions:[]});B.openMenu=null;renderBuilder();}
  function removeWhen(wi){B.conditions[B.sel].whens.splice(wi,1);B.openMenu=null;renderBuilder();}
  function toggleChipMenu(wi,ai){const k='c'+wi+'_'+ai;B.openMenu=B.openMenu===k?null:k;renderBuilder();}
  function deleteAction(wi,ai){B.conditions[B.sel].whens[wi].actions.splice(ai,1);B.openMenu=null;renderBuilder();}

  /* ---- action drawers ---- */
  const REDEEM_ACTIONS=[{label:'Allocation points',ic:'🪙'},{label:'Change customer status & label',ic:'👤'},{label:'Enrol in loyalty promotion',ic:'🏷️'},{label:'Forward to set',ic:'⏩'},{label:'Issue badge',ic:'🎖️'},{label:'Issue catalog reward',ic:'🎫'},{label:'Issue coupon',ic:'🎟️'},{label:'Issue loyalty promotion',ic:'🏷️'},{label:'Redeem group points',ic:'🏆'},{label:'Renew tier',ic:'🔄'},{label:'Send mail',ic:'✉️'},{label:'Send messages',ic:'💬'},{label:'Send SMS',ic:'📩'},{label:'Tag customer',ic:'🏷️'},{label:'Upgrade to tier',ic:'⬆️'},{label:'Issue AC_Points',ic:'🪙'},{label:'Issue Neucoin',ic:'🪙'}];
  let DR={open:false,mode:null,selected:null,wi:null,ai:null};
  function openAddDrawer(wi){DR={open:true,mode:'add',selected:null,wi:wi,ai:null};B.openMenu=null;renderBuilder();renderDrawer();}
  function openEditDrawer(wi,ai){DR={open:true,mode:'edit',selected:null,wi:wi,ai:ai};B.openMenu=null;renderBuilder();renderDrawer();}
  function closeDrawer(){DR.open=false;renderDrawer();}
  function selectActCard(i){DR.selected=i;renderDrawer();}
  function saveDrawer(){const c=B.conditions[B.sel];if(DR.mode==='add'){if(DR.selected==null)return;const a=REDEEM_ACTIONS[DR.selected];c.whens[DR.wi].actions.push({name:a.label,strategy:'GroupRedemption'});toast(a.label+' added.');}else{const sel=document.getElementById('editStrat');if(sel)c.whens[DR.wi].actions[DR.ai].strategy=sel.value;toast('Action updated.');}DR.open=false;renderDrawer();renderBuilder();}
  function renderDrawer(){
    const host=document.getElementById('drawerHost');if(!host)return;if(!DR.open){host.innerHTML='';return;}
    const X=`<button onclick="closeDrawer()" style="border:none;background:transparent;font-size:22px;cursor:pointer;color:var(--ink)">&times;</button>`;
    if(DR.mode==='add'){
      const cards=REDEEM_ACTIONS.map((a,i)=>{
        if(!SCENARIOS[SCi].org && a.label==='Redeem group points') return `<div class="act-card dis tip-host"><span class="dim"><span class="ai2">${a.ic}</span><span>${a.label}</span></span><span class="tip">Group redemption is inactive in Organisation settings. Enable it to add this action.</span></div>`;
        return `<div class="act-card ${DR.selected===i?'sel':''}" onclick="selectActCard(${i})"><span class="ai2">${a.ic}</span><span>${a.label}</span>${DR.selected===i?'<span class="chk">✓</span>':''}</div>`;
      }).join('');
      host.innerHTML=`<div class="dr-back" onclick="closeDrawer()"></div><div class="drawer"><div class="dr-head"><h3>Add action</h3>${X}</div><div class="dr-body">${cards}</div><div class="dr-foot"><button class="btn btn-primary" ${DR.selected!=null?'':'disabled'} onclick="saveDrawer()">Save</button></div></div>`;
    }else{
      const a=B.conditions[B.sel].whens[DR.wi].actions[DR.ai];
      const opts=STRATS.map(s=>`<option ${s===a.strategy?'selected':''}>${s}</option>`).join('');
      host.innerHTML=`<div class="dr-back" onclick="closeDrawer()"></div><div class="editpanel"><div class="ep-head"><h3>Edit action: ${a.name}</h3>${X}</div><div class="ep-body"><div class="ep-row"><span class="l">Points redemption strategy</span><select class="fld-sel" id="editStrat">${opts}</select></div></div><div class="ep-foot"><button class="btn btn-primary" onclick="saveDrawer()">Save</button></div></div>`;
    }
  }
  document.addEventListener('click',e=>{if(B.openMenu&&!e.target.closest('.menu')&&!e.target.closest('.dots')&&!e.target.closest('.addact')){B.openMenu=null;renderBuilder();}});

  /* ---- advanced settings ---- */
  function setStep(n){document.getElementById('s2').className=n>=2?'on':'';document.getElementById('s3').className=n>=3?'on':'';}
  function openSettings(target){document.getElementById('setOverlay').classList.add('open');document.body.style.overflow='hidden';setStep(2);selectSection('redemption');}
  function closeSettings(){document.getElementById('setOverlay').classList.remove('open');document.body.style.overflow='';setStep(1);}
  function clearNav(){document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));}
  function renderEmpty(){document.getElementById('advContent').innerHTML=`<div class="empty"><div class="big">⚙️</div><h3>Choose a setting to configure</h3><p>Select a section from the left. <b>Redemption scope</b> is new — set group vs. individual redemption per points type.</p><div class="arrow">← Open “Redemption scope”</div></div>`;}
  function selectSection(kind,label){
    setStep(kind==='redemption'||kind==='priority'?3:2);clearNav();
    if(kind==='redemption'){document.getElementById('navRedemption').classList.add('active');document.getElementById('panelTitle').textContent='Advanced settings: Redemption scope';renderRedemption();}
    else if(kind==='priority'){document.getElementById('navPriority').classList.add('active');document.getElementById('panelTitle').textContent='Advanced settings: Redemption priority';renderPriority();}
    else{[...document.querySelectorAll('.nav-item')].find(n=>n.textContent.trim().startsWith(label))?.classList.add('active');document.getElementById('panelTitle').textContent='Advanced settings: '+label;document.getElementById('advContent').innerHTML=`<div class="sec-head"><div><h2>${label}</h2><p>This section already exists in Loyalty+. It isn’t part of this prototype — the focus here is <b>Redemption scope</b>.</p></div></div><div class="note tips"><span class="ic">💡</span><span><span class="pfx">Tips:&nbsp;</span>Open <b>Redemption scope</b> from the left to see the new configuration.</span></div>`;}
  }

  /* ---- redemption scope (single program, checkbox) ---- */
  function renderRedemption(){
    document.getElementById('advContent').innerHTML=`
      <div class="sec-head">
        <div>
          <h2>Define redemption scope by points category</h2>
          <div class="prog2">Program: <b>Tata NeuPass</b></div>
          <p>Choose which categories of points earned in this program can be redeemed across the group. Unchecked categories stay <b>Individual</b> — redeemable only within this program. Promotional points can be set per specific promotion.</p>
        </div>
        <div class="head-actions"></div>
      </div>
      <div class="note pending" id="pendingNote" style="display:none"><span class="ic">⏱</span><span><span class="pfx">Pending:&nbsp;</span>Changes submitted for approval. They go live once an approver signs off.</span></div>
      <div class="cbx-head">Redeemable across the group — by points category${gAllowed()?'':infoTip(gReason()+' Every category stays Individual until this is resolved, so all options are unchecked and read-only.')}</div>
      <div class="cbx-list" id="cbxList"></div>
      <div class="scope-foot" id="scopeFoot"></div>`;
    renderCats();renderFoot();
    if(status!=='Live'){const pn=document.getElementById('pendingNote');if(pn)pn.style.display='flex';}
  }
  function editable(){return gAllowed()&&status==='Live';}
  function dirty(){return JSON.stringify(CATS)!==JSON.stringify(savedCATS);}
  function box(on,e,dis,onclick){return `<span class="cbx ${on?'on':''} ${e?'edit':''} ${dis?'dis':''}" ${e&&onclick?`onclick="${onclick}"`:''}>${on?'✓':''}</span>`;}
  function stateTag(on,dis){return `<span class="cbx-state ${on?'grp':'ind'} ${dis?'muted':''}">${on?'Shared':'Individual'}</span>`;}
  function infoTip(text){return `<span class="cap-tip" tabindex="0" aria-label="${text.replace(/"/g,'&quot;')}">ⓘ<span class="cap-tip-bub" role="tooltip">${text}</span></span>`;}
  function renderCats(){
    const e=editable(); let h='';
    CATS.forEach((c,i)=>{
      if(c.disabled){ // Benefits — shown, not selectable yet
        h+=`<div class="cbx-row dis"><span class="cbx dis"></span><div><div class="cbx-lbl">${c.label}</div><div class="cbx-sub">${c.sub}</div></div><span class="cbx-state muted">Not configurable yet</span></div>`;
        return;
      }
      if(c.expandable){ // Promotional points / Benefits — drill to specific items
        const unit=c.unit||'promotion';
        if(!gAllowed()){ // locked — accordion not expandable, everything Individual
          h+=`<div class="cbx-row dis"><span class="cbx dis"></span><div><div class="cbx-lbl">${c.label}</div><div class="cbx-sub">${c.sub}</div></div>${stateTag(false,true)}</div>`;
          return;
        }
        const tot=c.promos.length, g=c.promos.filter(p=>p.group).length;
        const summ=`${g} of ${tot} Shared`;
        const allOn=gAllowed()&&g===tot, someOn=gAllowed()&&g>0, pdis=!gAllowed();
        const pbox=`<span class="cbx ${allOn?'on':''} ${someOn&&!allOn?'part':''} ${e?'edit':''} ${pdis?'dis':''}" ${e&&!pdis?`onclick="event.stopPropagation();toggleAllPromos(${i})"`:''}>${allOn?'✓':(someOn?'–':'')}</span>`;
        h+=`<div class="cbx-row cat-parent ${e?'edit':''}" onclick="toggleExpand(${i})"><span class="caret">${c.open?'▾':'▸'}</span>${pbox}<div><div class="cbx-lbl">${c.label}</div><div class="cbx-sub">${c.sub} · set all, or per ${unit}</div></div><span class="cbx-state muted">${gAllowed()?summ:'Individual'}</span></div>`;
        if(c.open){
          const cq=c.query||'';
          h+=`<div class="promo-search"><span style="color:var(--sec);font-size:13px">🔍</span><input id="psearch-${i}" type="text" placeholder="Search ${unit}s…" value="${cq.replace(/"/g,'&quot;')}" oninput="filterPromos(${i},this.value)"></div>`;
          const q=cq.trim().toLowerCase();
          const matches=c.promos.map((pr,j)=>({pr,j})).filter(o=>!q||o.pr.label.toLowerCase().includes(q)||o.pr.sub.toLowerCase().includes(q));
          if(matches.length===0){h+=`<div class="promo-empty"><div class="pe-ic">🔍</div><div class="pe-t">No ${unit}s match “${cq}”</div><div class="pe-s">Check the spelling or try a different name or type.</div><button class="pe-clear" onclick="filterPromos(${i},'')">Clear search</button></div>`;}
          matches.forEach(({pr,j})=>{
            const on=gAllowed()?pr.group:false, dis=!gAllowed();
            h+=`<div class="cbx-row sub ${e?'edit':''} ${dis?'dis':''}">${box(on,e,dis,`togglePromo(${i},${j})`)}<div><div class="cbx-lbl">${pr.label}</div><div class="cbx-sub">${pr.sub}</div></div>${stateTag(on,dis)}</div>`;
          });
        }
        return;
      }
      const on=gAllowed()?c.group:false, dis=!gAllowed();
      h+=`<div class="cbx-row ${e?'edit':''} ${dis?'dis':''}">${box(on,e,dis,`toggleCat(${i})`)}<div><div class="cbx-lbl">${c.label}</div><div class="cbx-sub">${c.sub}</div></div>${stateTag(on,dis)}</div>`;
    });
    document.getElementById('cbxList').innerHTML=h;
  }
  function toggleExpand(i){CATS[i].open=!CATS[i].open;if(!CATS[i].open)CATS[i].query='';renderCats();}
  function toggleCat(i){if(!editable())return;CATS[i].group=!CATS[i].group;renderCats();renderFoot();}
  function togglePromo(i,j){if(!editable())return;CATS[i].promos[j].group=!CATS[i].promos[j].group;renderCats();renderFoot();}
  function toggleAllPromos(i){if(!editable())return;const all=CATS[i].promos.every(p=>p.group);CATS[i].promos.forEach(p=>p.group=!all);renderCats();renderFoot();}
  function filterPromos(i,v){CATS[i].query=v;renderCats();const inp=document.getElementById('psearch-'+i);if(inp){inp.focus();const n=inp.value.length;inp.setSelectionRange(n,n);}}
  function renderFoot(){const f=document.getElementById('scopeFoot');
    if(editable()){f.innerHTML=`<button class="btn btn-secondary" ${dirty()?'':'disabled'} onclick="resetScope()">Reset</button><button class="btn btn-primary" ${dirty()?'':'disabled'} onclick="submitForApproval()">Submit for approval</button>`;}
    else f.innerHTML='';}
  function resetScope(){CATS=JSON.parse(JSON.stringify(savedCATS));renderCats();renderFoot();}
  function submitForApproval(){savedCATS=JSON.parse(JSON.stringify(CATS));status='Awaiting';renderRedemption();toast('Redemption scope submitted for approval.');}

  /* ---- redemption priority (related CR) ---- */
  const PROGRAMS=[{name:'Tata NeuPass',note:'Umbrella program'},{name:'Taj · IHCL',note:'Brand program'},{name:'Tata CLiQ',note:'Brand program'}];
  let priMode='exp';                 // 'exp' = expiry only (backend), 'pri' = priority first, 'exppri' = expiry + priority
  let priOrder=[0,1,2];              // indices into PROGRAMS, top = highest priority
  let revOrder=[0,1,2];              // partial-reversal credit order, top = credited back first
  let priSavedMode='exp', priSaved=[0,1,2], priRevSaved=[0,1,2], priStatus='Live';
  function priEditable(){return gAllowed()&&priStatus==='Live';}
  function priDirty(){return JSON.stringify([priMode,priOrder,revOrder])!==JSON.stringify([priSavedMode,priSaved,priRevSaved]);}
  function renderPriority(){
    document.getElementById('advContent').innerHTML=`
      <div class="sec-head">
        <div>
          <h2>Set redemption priority</h2>
          <div class="prog2">Across programs · <b>Tata Digital SIT</b></div>
          <p>When a group redemption can draw from more than one program, this decides the order points are spent in.</p>
        </div>
        <div class="head-actions"></div>
      </div>
      ${gAllowed()
        ?`<div class="note tips"><span class="ic">💡</span><span><span class="pfx">Tips:&nbsp;</span>Keep <b>Expiry</b> unless a brand needs a specific program spent first (e.g. employee/wage points) — use <b>Priority first</b>, or <b>Expiry + priority</b> to let expiry lead and ranking break ties.</span></div>`
        :`<div class="note warn"><span class="ic">ⓘ</span><span><span class="pfx">Note:&nbsp;</span>${gReason()} Priority only applies to group redemption, so it's read-only until this is resolved.</span></div>`}
      <div class="note pending" id="priPending" style="display:none"><span class="ic">⏱</span><span><span class="pfx">Pending:&nbsp;</span>Changes submitted for approval. They go live once an approver signs off.</span></div>
      <div class="cbx-head">When points could come from more than one program, decide by</div>
      <div class="radg" id="priSeg" role="radiogroup"></div>
      <div class="note tips" id="priHint" style="background:var(--n1);color:var(--sec)"></div>
      <div id="priRankWrap">
        <div class="cbx-head" style="margin-top:6px">Priority order <span style="font-weight:400;color:var(--tert)">— rank the programs (top spends first)</span></div>
        <div class="pri-list" id="priList"></div>
      </div>
      <div class="cbx-head" style="margin-top:16px">Returns (reversal)</div>
      <div class="note tips" style="background:var(--n1);color:var(--sec)"><span><span class="pfx">Full reversal:&nbsp;</span>each chunk of points returns to the program it came from — fixed, nothing to set up.</span></div>
      <div class="cbx-head" style="margin-top:6px">Partial reversal — credit order <span style="font-weight:400;color:var(--tert)">— rank which program is credited back first</span></div>
      <div class="pri-list" id="revList"></div>
      <div class="scope-foot" id="priFoot"></div>`;
    renderPriSeg();renderPriHint();renderPriList();renderRevList();renderPriFoot();updatePriRank();
    if(priStatus!=='Live'){const pn=document.getElementById('priPending');if(pn)pn.style.display='flex';}
  }
  function renderPriSeg(){
    const e=priEditable();
    const opt=(m,lbl,by)=>`<div class="rad ${priMode===m?'on':''} ${e?'':'dis'}" role="radio" aria-checked="${priMode===m}" ${e?`onclick="setPriMode('${m}')"`:''}><span class="ctl"></span><div><div class="rl">${lbl}</div><div class="rb">${by}</div></div></div>`;
    document.getElementById('priSeg').innerHTML=
      opt('exp','Expiry','Spend the soonest-expiring points first. Handled by the system (default).')+
      opt('pri','Priority first','Spend points in the ranking order below first.')+
      opt('exppri','Expiry + priority','Expiry leads; the ranking below breaks same-day ties.');
  }
  function renderPriHint(){
    const h=document.getElementById('priHint');
    if(priMode==='exp') h.innerHTML=`<span><span class="pfx">How it works:&nbsp;</span>Soonest-to-expire points are spent first — decided automatically by the system. There's nothing to configure here.</span>`;
    else if(priMode==='pri') h.innerHTML=`<span><span class="pfx">How it works:&nbsp;</span>Points are spent in the ranking order below first — even if a lower-ranked program's points expire sooner. Expiry only decides within the same program.</span>`;
    else h.innerHTML=`<span><span class="pfx">How it works:&nbsp;</span>Soonest-to-expire points are spent first; the ranking below is used only to break ties when two batches expire on the same day.</span>`;
  }
  function updatePriRank(){const w=document.getElementById('priRankWrap');if(w)w.style.display=(priMode==='exp')?'none':'';}
  function renderPriList(){
    const e=priEditable();
    document.getElementById('priList').innerHTML=priOrder.map((p,i)=>{
      const prog=PROGRAMS[p];
      const dnd=e?`draggable="true" ondragstart="priDragStart(event,${i})" ondragover="priDragOver(event)" ondragleave="priDragLeave(event)" ondrop="priDrop(event,${i})" ondragend="priDragEnd()"`:'';
      return `<div class="pri-row ${e?'draggable':'dis'}" ${dnd}><span class="pri-grip">⠿</span><span class="pri-num">${i+1}</span><div class="pri-nm">${prog.name}<small>${prog.note}</small></div>${e?'<span class="pri-hint">Drag to reorder</span>':''}</div>`;
    }).join('');
  }
  function renderPriFoot(){const f=document.getElementById('priFoot');
    if(priEditable()){f.innerHTML=`<button class="btn btn-secondary" ${priDirty()?'':'disabled'} onclick="priReset()">Reset</button><button class="btn btn-primary" ${priDirty()?'':'disabled'} onclick="priSubmit()">Submit for approval</button>`;}
    else f.innerHTML='';}
  function setPriMode(m){if(!priEditable())return;priMode=m;renderPriSeg();renderPriHint();updatePriRank();renderPriFoot();}
  function renderRevList(){
    const e=priEditable();
    document.getElementById('revList').innerHTML=revOrder.map((p,i)=>{
      const prog=PROGRAMS[p];
      const dnd=e?`draggable="true" ondragstart="revDragStart(event,${i})" ondragover="revDragOver(event)" ondragleave="revDragLeave(event)" ondrop="revDrop(event,${i})" ondragend="revDragEnd()"`:'';
      return `<div class="pri-row ${e?'draggable':'dis'}" ${dnd}><span class="pri-grip">⠿</span><span class="pri-num">${i+1}</span><div class="pri-nm">${prog.name}<small>${prog.note}</small></div>${e?'<span class="pri-hint">Drag to reorder</span>':''}</div>`;
    }).join('');
  }
  let revDragFrom=null;
  function revDragStart(e,i){if(!priEditable())return;revDragFrom=i;e.currentTarget.classList.add('dragging');if(e.dataTransfer){e.dataTransfer.effectAllowed='move';}}
  function revDragOver(e){if(revDragFrom===null)return;e.preventDefault();document.querySelectorAll('#revList .pri-row').forEach(x=>x.classList.remove('dragover'));e.currentTarget.classList.add('dragover');}
  function revDragLeave(e){e.currentTarget.classList.remove('dragover');}
  function revDragEnd(){revDragFrom=null;document.querySelectorAll('#revList .pri-row').forEach(x=>{x.classList.remove('dragover');x.classList.remove('dragging');});}
  function revDrop(e,i){e.preventDefault();if(revDragFrom===null||!priEditable())return;const f=revDragFrom;revDragEnd();if(f===i)return;const item=revOrder.splice(f,1)[0];revOrder.splice(i,0,item);renderRevList();renderPriFoot();}
  let priDragFrom=null;
  function priDragStart(e,i){if(!priEditable())return;priDragFrom=i;e.currentTarget.classList.add('dragging');if(e.dataTransfer){e.dataTransfer.effectAllowed='move';}}
  function priDragOver(e){if(priDragFrom===null)return;e.preventDefault();document.querySelectorAll('.pri-row').forEach(x=>x.classList.remove('dragover'));e.currentTarget.classList.add('dragover');}
  function priDragLeave(e){e.currentTarget.classList.remove('dragover');}
  function priDragEnd(){priDragFrom=null;document.querySelectorAll('.pri-row').forEach(x=>{x.classList.remove('dragover');x.classList.remove('dragging');});}
  function priDrop(e,i){e.preventDefault();if(priDragFrom===null||!priEditable())return;const f=priDragFrom;priDragEnd();if(f===i)return;const item=priOrder.splice(f,1)[0];priOrder.splice(i,0,item);renderPriList();renderPriFoot();}
  function priReset(){priMode=priSavedMode;priOrder=priSaved.slice();revOrder=priRevSaved.slice();renderPriSeg();renderPriHint();renderPriList();renderRevList();updatePriRank();renderPriFoot();}
  function priSubmit(){priSavedMode=priMode;priSaved=priOrder.slice();priRevSaved=revOrder.slice();priStatus='Awaiting';renderPriority();toast('Redemption priority submitted for approval.');}

  function toast(msg){const w=document.getElementById('toastWrap');const t=document.createElement('div');t.className='toast';t.innerHTML=`<span class="tk">✓</span><span>${msg}</span>`;w.appendChild(t);requestAnimationFrame(()=>t.classList.add('show'));setTimeout(()=>{t.classList.remove('show');setTimeout(()=>t.remove(),300);},3200);}

  applyScenario();renderBuilder();renderScn();
</script>
</body>
</html>
